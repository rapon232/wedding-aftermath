# Copy this to .env and fill in. For local dev, defaults are fine except SESSION_SECRET.

# Port the Express server listens on (local dev + inside the container)
PORT=3000

# Secret used to sign session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=change-me

# Local-dev data directory (ignored on the NAS, where DATA_PATH is used instead)
DATA_DIR=./data

# Display name for the admin guest created on first boot (code is printed to the log)
ADMIN_NAME=Mitio

# IANA timezone of the wedding venue. Photo EXIF times (which carry no timezone)
# are interpreted in this zone, and the gallery displays times in it.
EVENT_TZ=Europe/Rome

# --- Docker / NAS deployment only (ignored by `npm run dev`) ---
# Host port the container is published on; point the Cloudflare tunnel here.
HOST_PORT=3000

# Host folder on the NAS for media + DB. MUST be an ABSOLUTE path — leading slash!
#   ✅ correct:  /volume1/docker/wedding_aftermath_data
#   ❌ wrong:    volume1/docker/wedding_aftermath_data   (no slash → "undefined volume" error)
DATA_PATH=/volume1/docker/wedding_aftermath_data

# --- Invite emails (Resend) ---
# Public origin used in invite links + the card image (the deployed URL).
PUBLIC_URL=https://aftermath.mitio.tech
# Resend API key (resend.com → verify mitio.tech domain → API key). Empty = sending disabled.
RESEND_API_KEY=
# From header for invites (display name <address>). Address must be on the verified domain.
MAIL_FROM=Mitio Tech <mitio@mitio.tech>
